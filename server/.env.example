# Copia este archivo a .env y completa los valores.
# Nunca subas .env a git.

# Token de acceso — ver SUSCRIPCIONES.md: en pruebas usar el TEST del **Vendedor** test, no el de tu cuenta real.
MP_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxxxxxx

# URL pública HTTPS del backend (Render, Railway, PythonAnywhere, etc.)
BACKEND_URL=https://tu-api.onrender.com

# Tras pagar, MP redirige aquí (local: /gracias en tu API)
FRONTEND_RETURN_URL=http://localhost:5001/gracias

# Obligatorio en local: MP exige https al crear suscripción (usa Render/ngrok + /gracias)
MP_PUBLIC_BACK_URL=https://tu-api.onrender.com/gracias

# Monto mensual en CLP
PLAN_AMOUNT_CLP=15000

# Opcional: ID de plan ya creado en MP (Developers → Suscripciones). Si falta, la API lo busca o crea uno.
# MP_PREAPPROVAL_PLAN_ID=e2c7174a6c7b46f7827dc93db4848b3e

# Secreto opcional para validar webhooks (genera uno aleatorio)
WEBHOOK_SECRET=cambia-esto-por-un-secreto-largo

# Solo en tu Mac: activa Pro sin Mercado Pago (nunca en Render/producción)
SUBSCRIPTION_DEV_BYPASS=0
# DEV_PRO_EMAIL=tu@email.com

# Puerto local
PORT=5001
