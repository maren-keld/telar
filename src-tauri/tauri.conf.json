{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Telar",
  "version": "0.1.0",
  "identifier": "cl.telarapp.desktop",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "bash scripts/dev-server.sh",
    "beforeBuildCommand": "bash scripts/stamp-frontend.sh"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Telar",
        "width": 1280,
        "height": 860,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob:; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:5001 http://localhost:5001 http://127.0.0.1:1420 https://telar-api.onrender.com https://github.com https://objects.githubusercontent.com; media-src 'self' blob: data:; object-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["app", "nsis"],
    "externalBin": ["binaries/analyze_session"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "infoPlist": "Info.plist",
      "entitlements": "entitlements.plist"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQyOUM5NkRCM0E2ODU0RjIKUldUeVZHZzYyNWFjMGlCMVE0YjVsUHd1ZThNUC9JWjFzdlJGdDVhZGxKZ3M1bm1QUXdnM2Y1TXMK",
      "endpoints": [
        "https://github.com/maren-keld/telar/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
